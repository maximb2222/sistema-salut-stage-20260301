@model SalutClubAttendance.Web.Models.ClubMember
@{
    ViewData["Title"] = "Карточка клиента";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Карточка клиента</h2>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Изменить</a>
</div>

<div class="card form-section p-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">ФИО</dt>
        <dd class="col-sm-9">@Model.FullName</dd>

        <dt class="col-sm-3">Телефон</dt>
        <dd class="col-sm-9">@Model.PhoneNumber</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Абонемент</dt>
        <dd class="col-sm-9">@Model.MembershipType (@Model.MembershipStartDate.ToString("dd.MM.yyyy") - @Model.MembershipEndDate.ToString("dd.MM.yyyy"))</dd>

        <dt class="col-sm-3">Статус</dt>
        <dd class="col-sm-9">@(Model.IsActive ? "Активен" : "Неактивен")</dd>

        <dt class="col-sm-3">Количество посещений</dt>
        <dd class="col-sm-9">@Model.Visits.Count</dd>
    </dl>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">К списку</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Удалить</a>
</div>
