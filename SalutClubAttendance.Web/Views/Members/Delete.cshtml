@model SalutClubAttendance.Web.Models.ClubMember
@{
    ViewData["Title"] = "Удаление клиента";
}

<h2 class="mb-3 text-danger">Удаление клиента</h2>

<div class="card form-section p-4">
    <p>Вы действительно хотите удалить клиента <strong>@Model.FullName</strong>?</p>
    <p class="text-muted">Будут удалены связанные записи посещений.</p>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
    </form>
</div>
