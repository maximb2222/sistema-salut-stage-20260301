@model SalutClubAttendance.Web.Models.WorkoutSession
@{
    ViewData["Title"] = "Детали тренировки";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Детали тренировки</h2>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Изменить</a>
</div>

<div class="card form-section p-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">Название</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">Тренер</dt>
        <dd class="col-sm-9">@Model.TrainerName</dd>

        <dt class="col-sm-3">Начало</dt>
        <dd class="col-sm-9">@Model.StartsAt.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-3">Вместимость</dt>
        <dd class="col-sm-9">@Model.Capacity</dd>

        <dt class="col-sm-3">Описание</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Зарегистрировано посещений</dt>
        <dd class="col-sm-9">@Model.Visits.Count</dd>
    </dl>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">К списку</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Удалить</a>
</div>
