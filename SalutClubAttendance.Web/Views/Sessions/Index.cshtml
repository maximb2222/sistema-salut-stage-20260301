@model IEnumerable<SalutClubAttendance.Web.Models.WorkoutSession>
@{
    ViewData["Title"] = "Тренировки";
    var search = ViewData["Search"]?.ToString();
    var onlyUpcoming = ViewData["OnlyUpcoming"]?.ToString() == "True";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Расписание тренировок</h2>
    <a asp-action="Create" class="btn btn-primary">Добавить тренировку</a>
</div>

<div class="card form-section p-3 mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Поиск</label>
            <input class="form-control" name="search" value="@search" placeholder="Название или тренер" />
        </div>
        <div class="col-md-3 form-check ms-2">
            <input type="checkbox" class="form-check-input" id="onlyUpcoming" name="onlyUpcoming" value="true" checked="@onlyUpcoming" />
            <label class="form-check-label" for="onlyUpcoming">Только будущие</label>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary">Применить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>
</div>

<div class="card form-section p-3">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Дата и время</th>
                    <th>Тренировка</th>
                    <th>Тренер</th>
                    <th>Вместимость</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StartsAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.Title</td>
                        <td>@item.TrainerName</td>
                        <td>@item.Capacity</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Детали</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
