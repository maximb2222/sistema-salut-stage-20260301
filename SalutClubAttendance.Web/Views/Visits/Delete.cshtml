@model SalutClubAttendance.Web.Models.Visit
@{
    ViewData["Title"] = "Удаление посещения";
}

<h2 class="mb-3 text-danger">Удаление записи посещения</h2>

<div class="card form-section p-4">
    <p>Удалить запись от <strong>@Model.CheckInAt.ToString("dd.MM.yyyy HH:mm")</strong>?</p>
    <p>Клиент: <strong>@Model.ClubMember?.FullName</strong></p>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
    </form>
</div>
